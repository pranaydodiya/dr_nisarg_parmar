# Canonical site URL (Vercel production URL or custom domain; used for sitemap, OG, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://drnisargparmar.com

# Backend API URL (required for connecting frontend to Express backend)
# Development: http://localhost:5000/api
# Production: https://api.yourdomain.com/api (Hostinger VPS / reverse proxy)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Optional: default Open Graph image (1200x630), full HTTPS URL
# NEXT_PUBLIC_DEFAULT_OG_IMAGE=https://res.cloudinary.com/.../og.jpg

# MongoDB (required)
# Use SRV: mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
# If you get querySrv ECONNREFUSED, use the STANDARD string from Atlas instead (see docs/MONGODB_CONNECTION.md):
# MONGODB_URI=mongodb://user:pass@host1:27017,host2:27017,host3:27017/?ssl=true&replicaSet=atlas-xxx&authSource=admin
MONGODB_URI=

# JWT for admin login (min 32 chars; use: openssl rand -base64 32)
JWT_SECRET=

# Optional: first admin user. Either run npm run seed:admin OR call (with dev server running):
#   GET /api/admin/seed?secret=YOUR_JWT_SECRET
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=your-password
# SEED_ADMIN_NAME=Admin

# Upload (optional, for blog images)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
