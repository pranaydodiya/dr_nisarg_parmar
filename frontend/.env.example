# --- Vercel / Next.js (set these in the Vercel dashboard or .env.local) ---
# Canonical site URL (production domain; used for sitemap, OG, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://drnisargparmar.com

# Backend API base URL (server-side proxy and non-browser fetches use this)
# Dev: http://localhost:5000/api
# Prod: https://api.yourdomain.com/api (must match TLS + path; see docs/DEPLOY.md)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Optional: default Open Graph image (1200x630), full HTTPS URL
# NEXT_PUBLIC_DEFAULT_OG_IMAGE=https://res.cloudinary.com/.../og.jpg

# Optional: Google Business Profile (or Maps) URL — added to Physician JSON-LD sameAs for local SEO
# NEXT_PUBLIC_GOOGLE_BUSINESS_URL=https://g.page/your-listing

# --- Analytics (Phase 9) ---
# Vercel: enable “Web Analytics” and “Speed Insights” in the Vercel project dashboard (no env required).
# Optional GA4 Measurement ID (G-XXXXXXXXXX). When set, a cookie banner appears; GA4 loads only after “Accept analytics”.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Below: only if you run tooling against Mongo from this folder (optional) ---
# MongoDB (required)
# Use SRV: mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
# If you get querySrv ECONNREFUSED, use the STANDARD string from Atlas instead (see docs/MONGODB_CONNECTION.md):
# MONGODB_URI=mongodb://user:pass@host1:27017,host2:27017,host3:27017/?ssl=true&replicaSet=atlas-xxx&authSource=admin
MONGODB_URI=

# JWT for admin login (min 32 chars; use: openssl rand -base64 32)
JWT_SECRET=

# Optional: seed admin via backend (see docs/DEPLOY.md) — set vars in backend/.env, then:
#   npm run seed:admin --prefix backend

# Upload (optional, for blog images)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
