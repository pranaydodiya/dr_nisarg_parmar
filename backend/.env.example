# Server
PORT=5000
NODE_ENV=development

# Frontend origin for CORS (required in production)
# Example: https://drnisargparmar.com
FRONTEND_URL=http://localhost:3000

# MongoDB connection string (required)
# Use SRV: mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# JWT secret for admin auth (required, min 32 chars)
# Generate with: openssl rand -base64 32
JWT_SECRET=

# Cloudinary (optional, for blog/testimonial images)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
